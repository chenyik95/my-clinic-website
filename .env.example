# Copy this file to .env.local and fill in your values
# .env.local is gitignored (see .gitignore)

# Optional: Pull testimonials from Google Reviews (max 5 via Places API).
# 1. Enable "Places API (New)" in Google Cloud Console
# 2. Create an API key — Place ID is resolved automatically from the clinic's Google Maps link
GOOGLE_PLACES_API_KEY=
# Optional override if auto-detection ever fails:
# GOOGLE_PLACE_ID=ChIJxxxxxxxxxxxx