# Copy this file to .env.local and fill in your values
# .env.local is gitignored (see .gitignore)

# Required for the booking form to actually send emails.
# Get a free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Override the "from" email address used when sending.
# For Resend's free tier you can use "onboarding@resend.dev"
# Once you verify a domain, you can use something like bookings@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# Note: The clinic email recipient is currently hardcoded in app/actions.ts
# as hello@zenpulseclinic.my — update that when you have real contact details.